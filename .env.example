# Root-level environment reference for the PredictIQ monorepo.
# Each service has its own .env.example with full details.
# This file lists the minimal cross-service variables for local development.

# ── API service (services/api) ────────────────────────────────────────────────
# See services/api/.env.example for the complete variable list.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/predictiq
REDIS_URL=redis://127.0.0.1:6379
HMAC_KEY=change-me
UNSUBSCRIBE_SIGNING_SECRET=change-me
SENDGRID_API_KEY=SG.xxxx
FROM_EMAIL=noreply@example.com

# ── Frontend (frontend) ───────────────────────────────────────────────────────
# See frontend/.env.example for details.
NEXT_PUBLIC_API_URL=http://localhost:8080
