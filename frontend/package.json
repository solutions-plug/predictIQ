{
  "name": "predictiq-frontend",
  "version": "1.0.0",
  "description": "PredictIQ Landing Page with WCAG 2.1 AA Compliance",
  "private": true,
  "scripts": {
    "generate-client": "openapi-typescript ../services/api/openapi.yaml -o src/lib/api/schema.d.ts",
    "dev": "next dev",
    "build": "npm run generate-client && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:a11y": "jest --testPathPattern=accessibility",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chrome": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:safari": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:ci": "node scripts/run-e2e-tests.js",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm run test && npm run test:e2e",
    "lighthouse": "node scripts/lighthouse-audit.js",
    "axe": "node scripts/axe-audit.js",
    "a11y:manual": "node scripts/manual-testing-checklist.js",
    "a11y:all": "npm run test:a11y && npm run lighthouse && npm run axe",
    "playwright:install": "playwright install --with-deps",
    "analyze": "ANALYZE=true npm run build",
    "bundlewatch": "bundlewatch"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@next/bundle-analyzer": "15.3.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.12.1",
    "bundlewatch": "2.3.3",
    "jest": "^30.4.2",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "lighthouse": "^13.4.0",
    "openapi-typescript": "^7.0.0",
    "pa11y": "^9.1.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
