# Frontend Environment Variables
# Copy this file to .env.local and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are bundled into the browser build.

# ── Required ──────────────────────────────────────────────────────────────────
# URL of the backend API server — validated at build time by next.config.js.
# Must be a valid URL. Trailing slashes are stripped automatically.
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Optional / build-time ─────────────────────────────────────────────────────
# NODE_ENV is set automatically by Next.js (development | production | test).
# Do not set it here unless you have a specific reason.

# ── Content Security Policy ───────────────────────────────────────────────────
# The CSP nonce is generated per-request by src/middleware.ts.
# No manual configuration is required for the nonce.
# If you need to allowlist additional script sources (e.g. analytics CDN),
# edit the cspHeader array in src/middleware.ts.
